# Frontend Configuration
VITE_API_URL=http://localhost:5000/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# Backend Configuration
PORT=5000
NODE_ENV=development

# Frontend URL for payment redirects
FRONTEND_URL=http://localhost:5173

# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/namaste-stay?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_min_32_characters_long

# Gmail SMTP (for sending emails)
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_app_specific_password

# eSewa Payment Gateway Configuration
# Set ESEWA_MODE to 'test' for testing or 'production' for live payments
ESEWA_MODE=test

# Test Mode Credentials (provided by eSewa)
# ESEWA_TEST_MERCHANT_CODE=EPAYTEST
# ESEWA_TEST_SECRET_KEY=8gBm/:&EnhH.1/q

# Production Mode Credentials (configure in production)
ESEWA_MERCHANT_CODE=your_merchant_code_here
ESEWA_SECRET_KEY=your_secret_key_here

# Admin Credentials (for first-time setup)
ADMIN_EMAIL=admin@namastestay.com
ADMIN_PASSWORD=admin123
